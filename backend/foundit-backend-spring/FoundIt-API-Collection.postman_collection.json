{
  "info": {
    "name": "FoundIt AI Backend API",
    "description": "Complete API collection for FoundIt AI Lost & Found System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"John Doe\",\n  \"studentId\": \"STU2024001\",\n  \"phoneNumber\": \"9876543210\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Lost Items",
      "item": [
        {
          "name": "Report Lost Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"iPhone 14 Pro\",\n  \"description\": \"Black iPhone with blue case, cracked screen\",\n  \"category\": \"ELECTRONICS\",\n  \"color\": \"Black\",\n  \"brand\": \"Apple\",\n  \"lastSeenLocationId\": 1,\n  \"lastSeenTime\": \"2024-03-13T14:30:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/lost-items",
              "host": ["{{base_url}}"],
              "path": ["lost-items"]
            }
          }
        },
        {
          "name": "Get All Lost Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lost-items",
              "host": ["{{base_url}}"],
              "path": ["lost-items"]
            }
          }
        },
        {
          "name": "Get My Lost Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lost-items/my-items",
              "host": ["{{base_url}}"],
              "path": ["lost-items", "my-items"]
            }
          }
        }
      ]
    },
    {
      "name": "Found Items",
      "item": [
        {
          "name": "Report Found Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"iPhone\",\n  \"description\": \"Found near library entrance\",\n  \"imageUrl\": \"/files/download/image.jpg\",\n  \"foundLocationId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/found-items",
              "host": ["{{base_url}}"],
              "path": ["found-items"]
            }
          }
        },
        {
          "name": "Get All Found Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/found-items",
              "host": ["{{base_url}}"],
              "path": ["found-items"]
            }
          }
        },
        {
          "name": "Get Items at Security Desk",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/found-items/at-security-desk",
              "host": ["{{base_url}}"],
              "path": ["found-items", "at-security-desk"]
            }
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/files/upload",
              "host": ["{{base_url}}"],
              "path": ["files", "upload"]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications",
              "host": ["{{base_url}}"],
              "path": ["notifications"]
            }
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/unread/count",
              "host": ["{{base_url}}"],
              "path": ["notifications", "unread", "count"]
            }
          }
        }
      ]
    },
    {
      "name": "Locations",
      "item": [
        {
          "name": "Get All Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations",
              "host": ["{{base_url}}"],
              "path": ["locations"]
            }
          }
        },
        {
          "name": "Get Active Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations/active",
              "host": ["{{base_url}}"],
              "path": ["locations", "active"]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics (Admin)",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/analytics/dashboard",
              "host": ["{{base_url}}"],
              "path": ["analytics", "dashboard"]
            }
          }
        },
        {
          "name": "Get Common Lost Locations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/analytics/locations/common",
              "host": ["{{base_url}}"],
              "path": ["analytics", "locations", "common"]
            }
          }
        }
      ]
    },
    {
      "name": "QR Codes",
      "item": [
        {
          "name": "Generate QR Code (Base64)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/qr/location/1/base64",
              "host": ["{{base_url}}"],
              "path": ["qr", "location", "1", "base64"]
            }
          }
        }
      ]
    }
  ]
}
